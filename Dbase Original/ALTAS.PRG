** MENU ALTAS **
DO WHILE .T.
  STORE 0 TO VCOD,VC_P,VSALDO
  STORE SPACE(15) TO VAPEL,VNOM
  STORE SPACE(20)TO VDIR
  STORE SPACE(1) TO SINO
  CLEAR
  @1,1 TO 22,78 DOUBLE
  @4,31 SAY 'ALTAS DE CLIENTES'
  @3,30 TO 5,48 
  @21,2 SAY 'INGRESE CODIGO = (0 PARA SALIR)'
  STORE 0 TO VCOD
  @8,20 SAY 'CODIGO: ' GET VCOD PICTURE '9999'
  READ
  IF VCOD=0
       EXIT
  ENDIF
  SEEK VCOD
  IF .NOT. EOF()
       @12,15 SAY 'EL CLIENTE YA EXISTE... <PULSE ENTER>'
       @23,23
       WAIT
       @23,0
       LOOP
ELSE
       @10,20 SAY 'APELLIDO:  'GET VAPEL PICTURE '@!'
       @12,20 SAY 'NOMBRE:    'GET VNOM PICTURE '@!'
       @14,20 SAY 'DIRECCION:  'GET VDIR PICTURE '@!'
       @16,20 SAY 'CODIGO POSTAL:   'GET VC_P PICTURE '9999'
       @18,20 SAY 'SALDO:' GET VSALDO PICTURE '99999.99'
       READ 
       @23,28 SAY 'DATOS CORRECTOS? (S-N)' GET SINO PICT '@!'
       READ
       IF SINO='S'
            APPEND BLANK
            REPLACE COD WITH VCOD,APEL WITH VAPEL,NOM WITH ¨
VNOM,DIR WITH VDIR,C_P WITH VC_P,SALDO WITH VSALDO
            CLEAR
       ELSE
           CLEAR
           LOOP
       ENDIF
   ENDIF
ENDDO
CLEAR
RETURN