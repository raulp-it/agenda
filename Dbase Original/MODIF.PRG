**MENU MODIFICACIONES**
STORE SPACE(1) TO SINO
DO WHILE .T.
  CLEAR
  @1,1 TO 22,78 DOUBLE
  @4,26 SAY 'MODIFICACIONES DE CLIENTES'
  @3,25 TO 5,52
  @21,2 SAY 'INGRESE CODIGO = (0 PARA TERMINAR)'
  STORE 0 TO VCOD
  @8,20 SAY ' CODIGO;    'GET VCOD PICTURE '9999'
  READ
  IF VCOD = 0
       EXIT
  ENDIF
  SEEK VCOD
  IF EOF()
  @12,15 SAY 'EL CLIENTE ESPECIFICADO NO EXISTE...PULSE <ENTER>'
  @23,0
  WAIT ''
  @23,0
  LOOP
ELSE
    STORE APEL TO VAPEL
    STORE NOM TO VNOM
    STORE DIR TO VDIR
    STORE C_P TO VC_P
    STORE SALDO TO VSALDO
    @10,20 SAY 'APELLIDO:  'GET VAPEL PICTURE '@!'
    @12,20 SAY 'NOMBRE:    'GET VNOM PICTURE '@!'
    @14,20 SAY 'DIRECCION; 'GET VDIR PICTURE '@!'
    @16,20 SAY 'CODIGO POSTAL:'GET VC_P PICTURE '9999'
    @18,20 SAY 'SALDO:'GET VSALDO PICTURE '99999.99'
    READ
    @23,28 SAY 'DATOS CORRECTOS? (S/N)'GET SINO PICT '!'
    READ
    IF SINO = 'S'
          REPLACE COD WITH VCOD,APEL WITH VAPEL,NOM WITH VNOM,DIR ¨
WITH VDIR,C_P WITH VC_P,SALDO WITH VSALDO
    CLEAR
    ELSE
        CLEAR
        LOOP
    ENDIF
ENDIF 
ENDDO
CLEAR
RETURN
   
